# ==================== API 密钥（必填）====================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.deepseek.com/v1

# NapCat（必填）
NAPCAT_TOKEN=your-napcat-token
NAPCAT_BASE_URL=http://127.0.0.1:3000

# 可选 API
# BAIDU_API_KEY=your-baidu-api-key
# BAIDU_API_URL=https://qianfan.baidubce.com/v2/ai_search/web_search
# HEWEATHER_KEY=your-heweather-key
# DASHSCOPE_API_KEY=your-dashscope-api-key

# ==================== 机器人配置 ====================
BOT_QQ=0
ADMIN_QQ=

# 权限控制（空=不限制）
# PRIVATE_WHITELIST=123456,789012
# GROUP_WHITELIST=1080840249
# PRIVATE_BLACKLIST=
# GROUP_BLACKLIST=

# ==================== 邮件 (SMTP) ====================
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USERNAME=your-email@qq.com
# SMTP_PASSWORD=your-auth-code
# SMTP_FROM_EMAIL=your-email@qq.com
# SMTP_FROM_NAME=知慧
# SMTP_USE_TLS=true

# ==================== IMAP ====================
# IMAP_HOST=imap.qq.com
# IMAP_PORT=993

# ==================== QQ 空间 ====================
# QZONE_COOKIES=

# ==================== 可选覆盖（不设置则使用 config.py 默认值）====================
# 情绪参数
# RAPID_DECAY_FACTOR=0.9
# RAPID_DECAY_TIMEOUT=1800
# DELTA_SCALE=0.4
# DELTA_MAX=5
# FORGETTING_PROBABILITY=0.2
# ANCHOR_RESURRECT_FACTOR=0.4

# 好感度参数
# AFFECTION_HALF_LIFE=604800
# AFFECTION_MIN=0
# AFFECTION_MAX=10000

# 回复延迟
# MAIN_DELAY=6.0
# SILENT_DELAY=1.0
# MAX_REPLY_MESSAGES=3
# SEND_DELAY_MIN=0.8
# SEND_DELAY_MAX=3.8

# 回复概率
# PRIVATE_REPLY_PROBABILITY=1.0
# GROUP_REPLY_PROBABILITY=0.3

# 记忆参数
# TOPIC_SWITCH_TIME_THRESHOLD=90
# TOPIC_SWITCH_SIMILARITY=0.2
# INCREMENTAL_ORGANIZE_INTERVAL=10800
